{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpcUaObjectTypeSource",
  "description": "Source description of an OPC-UA ObjectType for ModelDesign XML generation",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description", "variable"],
  "examples": [
    {
      "name": "MotorType",
      "description": "Represents a production line motor",
      "variable": [
        {
          "name": "Speed",
          "data_type": "Double",
          "description": "Motor speed in rpm"
        },
        {
          "name": "AlarmCodes",
          "data_type": "Int32",
          "array_dimensions": [10],
          "description": "Active alarm codes"
        }
      ]
    }
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "ObjectType name (e.g. MotorType)",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },
    "description": {
      "type": "string",
      "description": "ObjectType description"
    },
    "variable": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "data_type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Variable name (BrowseName)",
            "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
          },
          "data_type": {
            "description": "OPC-UA data type (built-in or already-defined custom type)",
            "enum": [
              "Boolean",
              "SByte",
              "Byte",
              "Int16",
              "UInt16",
              "Int32",
              "UInt32",
              "Int64",
              "UInt64",
              "Float",
              "Double",
              "String",
              "DateTime",
              "Guid",
              "ByteString",
              "LocalizedText"
            ]
          },
          "array_dimensions": {
            "type": "array",
            "description": "Array dimensions if the variable is an array (e.g. [10] or [3,4])",
            "items": { "type": "integer", "minimum": 1 },
            "minItems": 1
          },
          "description": {
            "type": "string",
            "description": "Variable description"
          }
        }
      }
    }
  }
}
